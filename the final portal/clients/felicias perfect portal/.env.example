# Aqua portal — example environment variables.
#
# Copy to `.env.local` (or set in your deployment platform) and fill in
# the values you need. Everything is optional in development — the app
# falls back to safe defaults — but production deploys MUST set
# PORTAL_SESSION_SECRET and disable the security bypass.

# ────────────────────────────────────────────────────────────
# Security & sessions
# ────────────────────────────────────────────────────────────

# 32+ random bytes used to HMAC-sign admin session cookies. If unset
# the code falls back to a stable dev secret — fine for local, NEVER
# acceptable in prod (anyone can mint a session). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
PORTAL_SESSION_SECRET=

# Auth bypass for local dev. Set to "off" / "false" / "dev" or unset
# entirely to disable admin auth (useful for prototype / demo). Set to
# "strict" (or anything else) to require real sign-in. Production deploys
# must NOT set this to a permissive value.
NEXT_PUBLIC_PORTAL_SECURITY=strict

# Legacy alias for the same bypass — kept for back-compat. Set to "1"
# to skip auth. Prefer NEXT_PUBLIC_PORTAL_SECURITY going forward.
# NEXT_PUBLIC_PORTAL_DEV_BYPASS=

# Random string used to sign per-site preview-mode tokens (lets the
# admin share a "look at the unpublished draft" URL without granting
# full session access). Falls back to a stable dev value if unset.
PORTAL_PREVIEW_SECRET=

# ────────────────────────────────────────────────────────────
# Storage backend
# ────────────────────────────────────────────────────────────

# Where the portal stores org/site/page/user records. Choices:
#   file      — JSON on disk under .data/ (default; great for dev)
#   memory    — in-process, ephemeral (good for tests)
#   kv        — Upstash KV REST (set PORTAL_KV_URL + PORTAL_KV_TOKEN)
#   supabase  — Postgres via Supabase (set PORTAL_SUPABASE_URL + KEY)
PORTAL_BACKEND=file

# Upstash KV REST — only used when PORTAL_BACKEND=kv.
# PORTAL_KV_URL=https://<region>.upstash.io
# PORTAL_KV_TOKEN=<rest-token>

# Supabase — only used when PORTAL_BACKEND=supabase.
# PORTAL_SUPABASE_URL=https://<ref>.supabase.co
# PORTAL_SUPABASE_SERVICE_KEY=<service-role-key>

# Default site id used by API routes when the host header doesn't map
# to a site. Falls back to "luvandker".
# PORTAL_SITE_ID=luvandker

# ────────────────────────────────────────────────────────────
# Storefront / SEO
# ────────────────────────────────────────────────────────────

# Absolute base URL of the storefront — used for sitemap, OG images,
# email links. Falls back to https://localhost:3000 in dev.
# NEXT_PUBLIC_SITE_URL=https://luvandker.com

# Aqua portal URL surfaced in admin "Back to Aqua" links. Falls back
# to /aqua on the same origin.
# NEXT_PUBLIC_AQUA_PORTAL_URL=

# ────────────────────────────────────────────────────────────
# Stripe (only required when the e-commerce / donations plugins are
# installed and you actually want to take payments)
# ────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_…
# STRIPE_WEBHOOK_SECRET=whsec_…

# ────────────────────────────────────────────────────────────
# Shopify (only when the optional Shopify Storefront block is used)
# ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ────────────────────────────────────────────────────────────
# EasyPost (shipping labels, only when the Shipping plugin is configured
# to actually generate carrier labels)
# ────────────────────────────────────────────────────────────
# EASYPOST_API_KEY=

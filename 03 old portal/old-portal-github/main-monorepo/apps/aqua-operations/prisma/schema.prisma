generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tenants (Agencies) ────────────────────────────────────────────────────────

model Agency {
  id           String   @id @default(cuid())
  name         String
  logo         String?
  domain       String?  @unique
  primaryColor String   @default("#6366f1")
  isConfigured Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  clients      Client[]
  suiteAccess  AgencySuite[]
}

// Which suites each agency has enabled
model AgencySuite {
  id          String   @id @default(cuid())
  agencyId    String
  suiteId     String
  enabled     Boolean  @default(true)
  /// Per-suite, per-agency configuration (PluginConfigField values). JSON-encoded.
  config      String   @default("{}")
  /// When the suite was first installed for this agency
  installedAt DateTime @default(now())
  /// Last time the agency edited config
  updatedAt   DateTime @updatedAt
  agency      Agency   @relation(fields: [agencyId], references: [id])

  @@unique([agencyId, suiteId])
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  name            String
  role            String   @default("AgencyEmployee")
  customRoleId    String?
  agencyId        String?
  clientId        String?
  avatar          String?
  bio             String?
  department      String?
  status          String   @default("active")
  locationType    String?
  baseSalaryCents Int      @default(0)
  joinedDate      String?
  productAccess   String   @default("operations")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agency         Agency?           @relation(fields: [agencyId], references: [id])
  sessions       Session[]
  assignedBriefs BriefAssignment[]
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    Int
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ── Clients ───────────────────────────────────────────────────────────────────

model Client {
  id                  String    @id @default(cuid())
  agencyId            String
  name                String
  email               String
  stage               String    @default("lead")
  logo                String?
  websiteUrl          String?
  brandColor          String?
  portalName          String?
  discoveryAnswers    String    @default("{}")
  enabledSuiteIds     String    @default("[]")
  assignedEmployeeIds String    @default("[]")
  assignedFreelancers String    @default("[]")
  githubOwner         String?
  githubRepo          String?
  githubFilePath      String?
  cmsProvisioned      Boolean   @default(false)
  cmsProvisionedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  agency    Agency           @relation(fields: [agencyId], references: [id])
  resources ClientResource[]
  briefs    FulfilmentBrief[]
}

model ClientResource {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  url        String
  type       String   @default("document")
  uploadedBy Int?
  uploadedAt DateTime @default(now())

  client     Client   @relation(fields: [clientId], references: [id])
}

// ── Fulfilment ────────────────────────────────────────────────────────────────

model FulfilmentBrief {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  description String
  dueDate     String?
  status      String   @default("brief")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client       Client                  @relation(fields: [clientId], references: [id])
  assignees    BriefAssignment[]
  deliverables FulfilmentDeliverable[]
}

model BriefAssignment {
  id      String @id @default(cuid())
  briefId String
  userId  Int

  brief   FulfilmentBrief @relation(fields: [briefId], references: [id])
  user    User            @relation(fields: [userId], references: [id])

  @@unique([briefId, userId])
}

model FulfilmentDeliverable {
  id            String    @id @default(cuid())
  briefId       String
  clientId      String
  title         String
  url           String?
  notes         String?
  submittedBy   Int
  submittedAt   DateTime  @default(now())
  approvedAt    DateTime?
  revisionNotes String?
  status        String    @default("review")

  brief         FulfilmentBrief @relation(fields: [briefId], references: [id])
}

// ── Activity Logs ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  agencyId  String?
  clientId  String?
  userId    Int?
  type      String
  message   String
  category  String?
  createdAt DateTime @default(now())
}

// ── App State ─────────────────────────────────────────────────────────────────

model ApplicationState {
  id        String   @id @default(cuid())
  agencyId  String?
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([agencyId, key])
}

# Aqua Portal — Host Shell environment template.
# Copy to `.env` (gitignored) and fill in for local dev.

# ── Database (single Prisma client across all suites) ────────────────────────
# Local dev uses SQLite — file path is fine.
# Production (Vercel etc.) uses Postgres — point at a managed DB.
#   - Local dev:    DATABASE_URL="file:./dev.db"
#   - Production:   DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?schema=public"
DATABASE_URL="file:./dev.db"

# ── Plugin runtime ────────────────────────────────────────────────────────────
# Set to "1" to re-enable the legacy iframe renderer (multi-port topology).
# Leave unset / "0" for the consolidated single-domain plugin model.
NEXT_PUBLIC_BRIDGE_IFRAME_FALLBACK="0"

# ── Optional: third-party integrations (filled in via Marketplace > Configure) ─
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
# GITHUB_TOKEN=
# MAILGUN_API_KEY=

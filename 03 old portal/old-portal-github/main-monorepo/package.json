{
  "name": "aqua-portal-root",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup-db.sh",
    "dev": "cd apps/aqua-host-shell && node ../../node_modules/next/dist/bin/next dev -p 3000",
    "build": "cd apps/aqua-host-shell && node ../../node_modules/next/dist/bin/next build",
    "start": "cd apps/aqua-host-shell && node ../../node_modules/next/dist/bin/next start -p 3000",
    "dev:legacy:host": "cd apps/aqua-host-shell && node ../../node_modules/next/dist/bin/next dev -p 3001",
    "dev:legacy:client": "cd apps/aqua-client && node ../../node_modules/next/dist/bin/next dev -p 3002",
    "dev:legacy:crm": "cd apps/aqua-crm && node ../../node_modules/next/dist/bin/next dev -p 3003",
    "dev:legacy:operations": "cd apps/aqua-operations && node ../../node_modules/next/dist/bin/next dev -p 3004",
    "dev:legacy:finance": "cd apps/aqua-ops-finance && node ../../node_modules/next/dist/bin/next dev -p 3005",
    "dev:legacy:people": "cd apps/aqua-ops-people && node ../../node_modules/next/dist/bin/next dev -p 3006",
    "dev:legacy:revenue": "cd apps/aqua-ops-revenue && node ../../node_modules/next/dist/bin/next dev -p 3007",
    "dev:legacy:all": "npm run dev:legacy:host & npm run dev:legacy:client & npm run dev:legacy:crm & npm run dev:legacy:operations & npm run dev:legacy:finance & npm run dev:legacy:people & npm run dev:legacy:revenue & wait",
    "test": "npm test --workspace=@aqua/bridge",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "Bridge",
    "Templates"
  ],
  "overrides": {
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.2.2",
    "@tailwindcss/oxide-darwin-x64": "^4.2.2",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
    "@tailwindcss/oxide-linux-x64-musl": "^4.2.2",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lightningcss-darwin-x64": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-linux-x64-musl": "^1.32.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "react-is": "^19.2.5"
  }
}

# ── AQUA PORTAL V9 ────────────────────────────────────────────────────────
# Comprehensive Environment Template for Decentralized MFE Architecture

# 💎 CORE AUTH & IDENTITY
GEMINI_API_KEY="YOUR_KEY_HERE"
NEXT_PUBLIC_APP_ENVIRONMENT="production"      # production | staging | development

# 🌐 HOST SHELL CONFIGURATION
# The root URL of the primary orchestrator app (Live Application)
NEXT_PUBLIC_HOST_URL="http://localhost:3001"

# 🧩 MICRO-FRONTEND ENDPOINTS
# Define the URLs for each independent app. 
# Defaults to localhost:300x in dev mode if left blank.
NEXT_PUBLIC_CLIENT_URL="http://localhost:3002"
NEXT_PUBLIC_CRM_URL="http://localhost:3003"
NEXT_PUBLIC_OPERATIONS_URL="http://localhost:3004"

# 🔒 SECURITY
# Comma-separated list of origins allowed to communicate via the Bridge
ALLOWED_BRIDGE_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"

# 💾 DATABASE & STORAGE
# Each app maintains its own siloed DB (configured in their local .env)
# Root database URL if using a shared persistence layer
DATABASE_URL="file:./dev.db"

# 🎭 CMS INTEGRATION (Optional)
PAYLOAD_SECRET="YOUR_PAYLOAD_SECRET"
NEXT_PUBLIC_CMS_URL="http://localhost:3000"

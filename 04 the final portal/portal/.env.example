# Aqua portal — environment variables.
#
# Copy to .env.local for local dev. Production deploys MUST set
# PORTAL_SESSION_SECRET to a long random value (≥32 chars).

# Random secret used to HMAC-sign the session cookie.
# Local dev falls back to a fixed dev secret if unset.
PORTAL_SESSION_SECRET=

# Storage backend. "file" persists to .data/portal-state.json (default for dev).
# Production: switch to "kv" (Upstash) or "postgres" (later) once wired.
PORTAL_BACKEND=file

# Optional KV (Upstash REST) backend.
# PORTAL_KV_URL=
# PORTAL_KV_TOKEN=

# Security mode. "strict" enforces session checks on /portal/*.
# Unset / "dev" bypasses auth so the dev server is browsable without sign-in.
NEXT_PUBLIC_PORTAL_SECURITY=dev

# Public marketing site URL (used by /embed/login back-link).
NEXT_PUBLIC_PORTAL_BASE_URL=http://localhost:3030

# Optional backend pointer for future API split.
# PORTAL_BACKEND_URL=https://api.milesymedia.com
